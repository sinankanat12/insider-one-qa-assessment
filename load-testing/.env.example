# Target
TARGET_BASE_URL=https://www.n11.com

# Default test parameters (UI can override)
DEFAULT_USER_COUNT=1
DEFAULT_SPAWN_RATE=1
DEFAULT_DURATION_SECONDS=60

# Locust paths (container-internal, must match volume mount)
LOCUST_RESULTS_DIR=/app/results
LOCUST_CONFIG_DIR=/app/results

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_ENV=production
LOG_LEVEL=info

# Frontend (Vite env variables — used at build time)
VITE_API_BASE_URL=
VITE_STATUS_POLL_INTERVAL_MS=1000
VITE_METRICS_POLL_INTERVAL_MS=3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://load-frontend:80
